// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "r/science Causal Graph",
	"image": "mcr.microsoft.com/devcontainers/python:3-3.14-trixie",

	// Forward API and frontend dev server ports
	"forwardPorts": [8000, 5173],
	"portsAttributes": {
		"8000": { "label": "FastAPI", "onAutoForward": "notify" },
		"5173": { "label": "Frontend (Vite)", "onAutoForward": "openBrowser" }
	},

	// Install all Python and Node.js dependencies after container creation
	"postCreateCommand": "bash .devcontainer/setup.sh",

	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.debugpy",
				"ms-python.vscode-pylance"
			],
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python",
				"editor.formatOnSave": true,
				"[python]": {
					"editor.defaultFormatter": "charliermarsh.ruff"
				}
			}
		}
	}
}
