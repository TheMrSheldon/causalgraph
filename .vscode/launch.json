{
  "version": "0.2.0",
  "configurations": [
    // -----------------------------------------------------------------------
    // Pipeline steps
    // -----------------------------------------------------------------------
    {
      "name": "Pipeline: Run All Steps",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_pipeline.py",
      "args": ["--config", "config.yaml"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Pipeline: Step 1 – Identify Causal Posts",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_pipeline.py",
      "args": ["--step", "1"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Pipeline: Step 2 – Extract Causal Pairs",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_pipeline.py",
      "args": ["--step", "2"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Pipeline: Step 3 – Build Hierarchy",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_pipeline.py",
      "args": ["--step", "3"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    // -----------------------------------------------------------------------
    // Python Servers
    // -----------------------------------------------------------------------
    {
      "name": "Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "api.main:app",
        "--reload",
        "--host", "0.0.0.0",
        "--port", "8000"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Pipeline Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "pipeline.server:app",
        "--reload",
        "--host", "0.0.0.0",
        "--port", "8001"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    // -----------------------------------------------------------------------
    // Tests
    // -----------------------------------------------------------------------
    {
      "name": "Tests: Run All",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Tests: Current File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    // -----------------------------------------------------------------------
    // Utilities
    // -----------------------------------------------------------------------
    {
      "name": "Inspect Parquet Schema",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/inspect_parquet.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: API + (manual) Frontend",
      "configurations": ["Backend", "Pipeline Server"],
      "presentation": {
        "hidden": false,
        "group": "Full Stack",
        "order": 1
      },
      "stopAll": true
    }
  ]
}
