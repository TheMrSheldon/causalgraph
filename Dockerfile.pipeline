# pytorch/pytorch ships Python 3.11; we install deps with --ignore-requires-python
# so the >= 3.12 pyproject constraint doesn't block the install (code is 3.11-compatible).
FROM pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime

# System build tools needed by some Python wheels (hdbscan, etc.)
RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc g++ && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── Python dependencies ───────────────────────────────────────────────────────
# Core data / pipeline
RUN pip install --no-cache-dir --ignore-requires-python \
    "duckdb>=1.1.0" \
    "pyarrow>=18.0.0" \
    "pyyaml>=6.0" \
    "pydantic>=2.7.0"

# Step 2: spaCy extractor
RUN pip install --no-cache-dir --ignore-requires-python "spacy>=3.7.0" && \
    python -m spacy download en_core_web_sm

# Step 3 / 4: clustering & embeddings
RUN pip install --no-cache-dir --ignore-requires-python \
    "sentence-transformers>=3.0.0" \
    "hdbscan>=0.8.38" \
    "scikit-learn>=1.5.0" \
    "numpy>=1.26.0"

# Step 3: transformer canonizer (Qwen/Mistral etc.)
RUN pip install --no-cache-dir --ignore-requires-python "transformers>=4.40.0"

# API server + optional LLM canonizer clients
RUN pip install --no-cache-dir --ignore-requires-python \
    "fastapi>=0.111.0" \
    "uvicorn[standard]>=0.30.0" \
    "httpx>=0.27.0" \
    "openai>=1.30.0" \
    "anthropic>=0.28.0"

# ── Application source ────────────────────────────────────────────────────────
COPY pipeline/ ./pipeline/
COPY api/      ./api/
COPY scripts/  ./scripts/
COPY config.yaml .

# ── Build metadata ────────────────────────────────────────────────────────────
ARG BUILD_VERSION=dev
ARG BUILD_DATE=unknown
ENV BUILD_VERSION=${BUILD_VERSION} \
    BUILD_DATE=${BUILD_DATE}

# ── Runtime configuration ─────────────────────────────────────────────────────
# Pipeline server: mount routes at /pipeline/* so lighttpd can proxy without
# path rewriting.  Leave empty ("") to keep the flat-root dev layout.
ENV PIPELINE_ROOT=/pipeline

# Data directory — mount your parquet + DB here:
#   docker run -v /host/data:/causalgraph ...
VOLUME /causalgraph

EXPOSE 8001

# Default: run the pipeline analysis server (text-analyzer backend).
# Override CMD to run the full pipeline:
#   docker run ... python scripts/run_pipeline.py --config /causalgraph/config.yaml
CMD ["uvicorn", "pipeline.server:app", "--host", "0.0.0.0", "--port", "8001"]
