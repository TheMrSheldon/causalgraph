# Base URL of the backend API server (protocol + host + port).
# When set, the browser connects directly — no Vite proxy needed.
# Leave unset (or empty) to use the Vite dev proxy (defaults to localhost:8000).
VITE_BACKEND_URL=http://localhost:8000

# Base URL of the pipeline server.
# Leave unset to use the Vite dev proxy (defaults to localhost:8001).
VITE_PIPELINE_URL=http://localhost:8001
